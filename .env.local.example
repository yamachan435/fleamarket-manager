# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Drive API (OAuth 2.0)
# GCPでOAuth 2.0クライアントIDを作成し、以下の環境変数を設定
# リダイレクトURI: http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Google Drive API (Service Account - オプション)
# OAuth認証が不要な場合に使用
# GCPでサービスアカウントを作成し、JSONキーをダウンロードしてGOOGLE_PRIVATE_KEYに設定
# サービスアカウントにGoogle Drive APIへのアクセス権限を付与すること
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"